# Frontend Environment Variables

# API Base URL - set based on your environment
# For production: https://helpdesk.hubblehox.ai
# For local development: http://localhost:3003
# If not set, the app will auto-detect based on current hostname
VITE_API_BASE_URL=https://helpdesk.hubblehox.ai

# WebSocket URL
# If not set, the app will auto-detect based on current hostname
VITE_WS_URL=wss://helpdesk.hubblehox.ai
