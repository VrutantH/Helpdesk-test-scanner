# ============================================================================
# Environment Configuration - SINGLE FILE for both LOCAL and PRODUCTION
# ============================================================================
# Set NODE_ENV=development for local, NODE_ENV=production for production server
# IMPORTANT: Change to 'production' when deploying to production server
NODE_ENV=development
PORT=3003

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Development (local) MongoDB
MONGODB_LOCAL_URI=mongodb://localhost:27017/sac_helpdesk
# Production MongoDB (with authentication)
MONGODB_PRODUCTION_URI=mongodb://helpdesk-dev:hELpDEsK-DeV2025@34.14.157.13:27017/sac_helpdesk?authSource=admin
DB_NAME=sac_helpdesk

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# CRITICAL: Change these secrets before deploying to production!
JWT_SECRET=SAC-Helpdesk-JWT-Secret-2025-CHANGE-THIS-IN-PRODUCTION-e8f9a0b1c2d3e4f5
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=SAC-Helpdesk-Refresh-JWT-Secret-2025-CHANGE-THIS-TOO-g6h7i8j9k0l1m2n3
JWT_REFRESH_EXPIRE=30d

# ============================================================================
# URL CONFIGURATION - Code auto-detects based on NODE_ENV
# ============================================================================
# These values are used based on NODE_ENV setting above
# LOCAL (NODE_ENV=development): Uses localhost values
# PRODUCTION (NODE_ENV=production): Uses production domain values

# Frontend URL
FRONTEND_URL_LOCAL=http://localhost:3001
FRONTEND_URL_PRODUCTION=https://helpdesk.hubblehox.ai

# Backend URL
BACKEND_URL_LOCAL=http://localhost:3003
BACKEND_URL_PRODUCTION=https://api.helpdesk.hubblehox.ai

# API URL
API_URL_LOCAL=http://localhost:3003/api
API_URL_PRODUCTION=https://api.helpdesk.hubblehox.ai/api

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS_LOCAL=http://localhost:3001,http://localhost:3000,http://localhost:3003
ALLOWED_ORIGINS_PRODUCTION=https://helpdesk.hubblehox.ai,https://api.helpdesk.hubblehox.ai

# Socket.io CORS Origin
SOCKET_CORS_ORIGIN_LOCAL=http://localhost:3001
SOCKET_CORS_ORIGIN_PRODUCTION=https://helpdesk.hubblehox.ai

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ============================================================================
# EMAIL CONFIGURATION (for notifications)
# ============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
