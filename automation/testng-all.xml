<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Run with: mvn test -Dmodule=all -->
<suite name="HubbleHox Full Suite" verbose="1" thread-count="1" parallel="none">

    <!-- ==================== LOGIN MODULE ==================== -->
    <test name="Login Tests">
        <classes>
            <class name="com.hubblehox.automation.tests.LoginTest"/>
        </classes>
    </test>

    <!-- ==================== PROJECT MANAGEMENT MODULE ==================== -->
    <test name="Project Management Tests">
        <classes>
            <class name="com.hubblehox.automation.tests.ProjectManagementTest"/>
        </classes>
    </test>

    <!-- Add more modules here as they are developed -->

</suite>
